{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://alphaforge.dev/schemas/strategy_spec.v1.json",
  "title": "AlphaForge Strategy Spec",
  "description": "Machine-readable, backtestable crypto trading strategy specification generated by AlphaForge.",
  "type": "object",
  "required": ["version", "generated_by", "asset", "quote_asset", "timeframe", "strategy_type", "market_regime", "features", "risk_management", "backtest", "evaluation_metrics"],
  "properties": {
    "version": { "type": "string" },
    "generated_by": { "type": "string", "const": "AlphaForge" },
    "asset": { "type": "string", "description": "Base asset symbol, e.g. BNB" },
    "quote_asset": { "type": "string", "const": "USDT" },
    "timeframe": {
      "type": "string",
      "enum": ["15m", "1h", "4h", "1d", "1w"]
    },
    "strategy_type": {
      "type": "string",
      "enum": ["regime_aware_momentum", "panic_reversal", "sentiment_divergence", "volatility_breakout", "no_trade"]
    },
    "market_regime": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string",
          "enum": ["bullish_trend", "bearish_trend", "low_volatility_accumulation", "high_volatility_chop", "panic_reversal", "sentiment_overheated", "derivatives_crowded_long", "derivatives_crowded_short", "neutral"]
        },
        "secondary": { "type": "array", "items": { "type": "string" } }
      }
    },
    "features": {
      "type": "object",
      "properties": {
        "technical": { "type": "array", "items": { "type": "string" } },
        "sentiment": { "type": "array", "items": { "type": "string" } },
        "derivatives": { "type": "array", "items": { "type": "string" } }
      }
    },
    "entry_rules": {
      "type": "object",
      "properties": {
        "all": { "type": "array", "items": { "type": "string" } },
        "any": { "type": "array", "items": { "type": "string" } }
      }
    },
    "exit_rules": {
      "type": "object",
      "properties": {
        "all": { "type": "array", "items": { "type": "string" } },
        "any": { "type": "array", "items": { "type": "string" } }
      }
    },
    "risk_management": {
      "type": "object",
      "required": ["max_position_size_pct", "stop_loss_pct", "max_strategy_drawdown_pct"],
      "properties": {
        "max_position_size_pct": { "type": "number", "minimum": 1, "maximum": 100 },
        "stop_loss_pct": { "type": "number", "minimum": 0.5, "maximum": 50 },
        "trailing_stop_pct": { "type": "number" },
        "max_strategy_drawdown_pct": { "type": "number", "minimum": 1, "maximum": 50 },
        "stop_loss_atr_multiple": { "type": "number" }
      }
    },
    "filters": { "type": "object" },
    "backtest": {
      "type": "object",
      "required": ["start_date", "end_date", "initial_capital"],
      "properties": {
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" },
        "initial_capital": { "type": "number", "minimum": 100 },
        "transaction_cost_bps": { "type": "number" },
        "slippage_bps": { "type": "number" },
        "benchmark": { "type": "string" }
      }
    },
    "evaluation_metrics": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
